<Window x:Class="LumaTray.Views.HotkeyConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LumaTray — Hotkey Settings"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="#202020">

    <StackPanel Margin="20" Width="340">
        <TextBlock Text="Global Hotkeys" FontSize="16" FontWeight="SemiBold"
                   Foreground="White" Margin="0,0,0,16"/>

        <!-- Brightness Up -->
        <TextBlock Text="Brightness Up" Foreground="#C8C8C8" FontSize="12" Margin="0,0,0,4"/>
        <TextBox x:Name="BrightnessUpBox" IsReadOnly="True" FontSize="13"
                 Height="32" Padding="6,4" Background="#2A2A2A" Foreground="White"
                 BorderBrush="#444" CaretBrush="White"
                 PreviewKeyDown="OnHotkeyKeyDown" GotFocus="OnHotkeyBoxFocus"
                 LostFocus="OnHotkeyBoxLostFocus" Cursor="Hand"/>

        <TextBlock Text="Brightness Down" Foreground="#C8C8C8" FontSize="12" Margin="0,12,0,4"/>
        <TextBox x:Name="BrightnessDownBox" IsReadOnly="True" FontSize="13"
                 Height="32" Padding="6,4" Background="#2A2A2A" Foreground="White"
                 BorderBrush="#444" CaretBrush="White"
                 PreviewKeyDown="OnHotkeyKeyDown" GotFocus="OnHotkeyBoxFocus"
                 LostFocus="OnHotkeyBoxLostFocus" Cursor="Hand"/>

        <!-- Step size -->
        <TextBlock Text="Step (%)" Foreground="#C8C8C8" FontSize="12" Margin="0,12,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="StepSlider" Minimum="1" Maximum="25" TickFrequency="1"
                    IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock x:Name="StepLabel" Grid.Column="1" Foreground="White" FontSize="13"
                       Width="32" TextAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    Click="OnCancel" Background="#333" Foreground="White" BorderBrush="#555"/>
            <Button Content="Save" Width="80" Height="28"
                    Click="OnSave" Background="#0078D4" Foreground="White" BorderBrush="#0078D4"/>
        </StackPanel>
    </StackPanel>
</Window>
