<Window x:Class="LumaTray.Views.HotkeyConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LumaTray — Hotkey Settings"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="#202020">

    <StackPanel Margin="20" Width="340">
        <TextBlock Text="Global Hotkeys" FontSize="16" FontWeight="SemiBold"
                   Foreground="White" Margin="0,0,0,4"/>
        <TextBlock Text="Hotkeys are disabled while this window is open."
                   Foreground="#888" FontSize="11" FontStyle="Italic" Margin="0,0,0,14"/>

        <!-- Brightness Up -->
        <TextBlock Text="Brightness Up" Foreground="#C8C8C8" FontSize="12" Margin="0,0,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="UpBorder" Height="32" Background="#2A2A2A" BorderBrush="#444"
                    BorderThickness="1" CornerRadius="3"
                    Focusable="True"
                    PreviewKeyDown="OnHotkeyKeyDown" PreviewKeyUp="OnHotkeyKeyUp">
                <TextBlock x:Name="BrightnessUpLabel" Foreground="White" FontSize="13"
                           VerticalAlignment="Center" Margin="8,0" IsHitTestVisible="False"/>
            </Border>
            <Button x:Name="UpRecordBtn" Grid.Column="1" Content="Record" Width="60" Height="28"
                    Margin="6,0,0,0" Click="OnRecordClick"
                    Background="#333" Foreground="White" BorderBrush="#555"/>
        </Grid>

        <TextBlock Text="Brightness Down" Foreground="#C8C8C8" FontSize="12" Margin="0,12,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="DownBorder" Height="32" Background="#2A2A2A" BorderBrush="#444"
                    BorderThickness="1" CornerRadius="3"
                    Focusable="True"
                    PreviewKeyDown="OnHotkeyKeyDown" PreviewKeyUp="OnHotkeyKeyUp">
                <TextBlock x:Name="BrightnessDownLabel" Foreground="White" FontSize="13"
                           VerticalAlignment="Center" Margin="8,0" IsHitTestVisible="False"/>
            </Border>
            <Button x:Name="DownRecordBtn" Grid.Column="1" Content="Record" Width="60" Height="28"
                    Margin="6,0,0,0" Click="OnRecordClick"
                    Background="#333" Foreground="White" BorderBrush="#555"/>
        </Grid>

        <TextBlock x:Name="ValidationLabel" Foreground="#E05050" FontSize="11"
                   TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed"/>

        <!-- Step size -->
        <TextBlock Text="Step (%)" Foreground="#C8C8C8" FontSize="12" Margin="0,12,0,4"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="StepSlider" Minimum="1" Maximum="25" TickFrequency="1"
                    IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
            <TextBlock x:Name="StepLabel" Grid.Column="1" Foreground="White" FontSize="13"
                       Width="32" TextAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    Click="OnCancel" Background="#333" Foreground="White" BorderBrush="#555"/>
            <Button Content="Save" Width="80" Height="28"
                    Click="OnSave" Background="#0078D4" Foreground="White" BorderBrush="#0078D4"/>
        </StackPanel>
    </StackPanel>
</Window>
