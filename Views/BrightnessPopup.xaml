<Window x:Class="BrightnessControl.Views.BrightnessPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <!-- Outer margin provides room for the drop shadow -->
    <Border Margin="10"
            Background="#E8202020"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              BlurRadius="18" ShadowDepth="4" Opacity="0.55"/>
        </Border.Effect>

        <StackPanel x:Name="MonitorsPanel"
                    Width="288"
                    Margin="16,14"/>
    </Border>
</Window>
