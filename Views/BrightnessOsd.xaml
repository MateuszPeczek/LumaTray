<Window x:Class="LumaTray.Views.BrightnessOsd"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="300"
        WindowStartupLocation="Manual">

    <Border Margin="10"
            Background="#E8202020"
            CornerRadius="10"
            Padding="16,12">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270"
                              BlurRadius="14" ShadowDepth="3" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header row: sun icon + percentage -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="☀" FontSize="16" Foreground="#FFC800"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="TitleLabel" Grid.Column="1" Text="Brightness"
                           Foreground="#C8C8C8" FontSize="12" Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="PercentLabel" Grid.Column="2"
                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- Progress bar -->
            <Border Background="#333" CornerRadius="3" Height="6">
                <Border x:Name="FillBar" Background="#0078D4" CornerRadius="3"
                        HorizontalAlignment="Left" Height="6"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
